pkgname=heroic-games-launcher-bin
pkgver=2.21.0
pkgrel=1
pkgdesc="Open source GOG and Epic games launcher (pre-built)"
arch=('x86_64')
url="https://github.com/Heroic-Games-Launcher/HeroicGamesLauncher"
license=('GPL-3.0-only')
depends=('gtk3' 'nss' 'libsecret')
provides=('heroic-games-launcher')
conflicts=('heroic-games-launcher')
source=("${pkgname}-${pkgver}.deb::https://github.com/Heroic-Games-Launcher/HeroicGamesLauncher/releases/download/v${pkgver}/Heroic-${pkgver}-linux-amd64.deb")
sha256sums=('SKIP')

package() {
    bsdtar xf data.tar.gz -C "${pkgdir}" 2>/dev/null || \
    bsdtar xf data.tar.xz -C "${pkgdir}" 2>/dev/null || true

    # Fix permissions
    chmod -R 755 "${pkgdir}/usr/share/heroic" 2>/dev/null || true
}
