pkgname=bibata-cursor-theme-bin
pkgver=2.0.7
pkgrel=1
pkgdesc="Material Based Cursor Theme (pre-built)"
arch=('any')
url="https://github.com/ful1e5/Bibata_Cursor"
license=('GPL-3.0-only')
provides=('bibata-cursor-theme')
conflicts=('bibata-cursor-theme')
source=("Bibata-${pkgver}.tar.xz::https://github.com/ful1e5/Bibata_Cursor/releases/download/v${pkgver}/Bibata.tar.xz")
sha256sums=('SKIP')

package() {
    install -dm755 "${pkgdir}/usr/share/icons"
    cp -r Bibata-Modern-Classic "${pkgdir}/usr/share/icons/" 2>/dev/null || true
    cp -r Bibata-Modern-Ice "${pkgdir}/usr/share/icons/" 2>/dev/null || true
    cp -r Bibata-Original-Classic "${pkgdir}/usr/share/icons/" 2>/dev/null || true
    cp -r Bibata-Original-Ice "${pkgdir}/usr/share/icons/" 2>/dev/null || true
}
