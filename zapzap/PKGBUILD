pkgname=zapzap
pkgver=6.2.1
pkgrel=1
pkgdesc="WhatsApp desktop client for Linux"
arch=('x86_64')
url="https://github.com/rafatosta/zapzap"
license=('GPL-3.0-only')
depends=('python' 'python-pyqt6' 'python-pyqt6-webengine' 'qt6-webengine')
makedepends=('python-build' 'python-installer' 'python-wheel' 'python-setuptools')
source=("${pkgname}-${pkgver}.tar.gz::https://github.com/rafatosta/zapzap/archive/refs/tags/${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
    cd "${pkgname}-${pkgver}"
    python -m build --wheel --no-isolation
}

package() {
    cd "${pkgname}-${pkgver}"
    python -m installer --destdir="${pkgdir}" dist/*.whl
}
