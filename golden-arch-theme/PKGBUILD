pkgname=golden-arch-theme
pkgver=1.0
pkgrel=2
pkgdesc="Golden Arch Linux KDE theme — Everforest Dark"
arch=('any')
url="https://github.com/golden-arch/packages"
license=('GPL-3.0-only')
depends=(
    'kvantum'
    'papirus-icon-theme'
    'bibata-cursor-theme-bin'
    'everforest-gtk-theme-git'
    'ttf-jetbrains-mono-nerd'
)
optdepends=('kde-gtk-config: apply GTK theme in KDE settings')

source=(
    "EverforestDark.colors"
    "EverforestDark.colorscheme"
    "Everforest.profile"
    "MateriaEverforestDark.kvconfig"
    "MateriaEverforestDark.svg"
    "kdeglobals"
    "kwinrc"
    "gtk-settings.ini"
    "goldenarch-centered-1080p.png"
    "goldenarch-centered-1440p.png"
    "goldenarch-offset-1080p.png"
    "goldenarch-offset-1440p.png"
    "goldenarch-16.png"
    "goldenarch-32.png"
    "goldenarch-48.png"
    "goldenarch-64.png"
    "goldenarch-128.png"
    "goldenarch-256.png"
    "goldenarch-512.png"
)
sha256sums=('SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP'
            'SKIP' 'SKIP' 'SKIP' 'SKIP'
            'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP')

package() {
    # KDE color scheme
    install -Dm644 EverforestDark.colors \
        "${pkgdir}/usr/share/color-schemes/EverforestDark.colors"

    # Konsole color scheme + profile
    install -Dm644 EverforestDark.colorscheme \
        "${pkgdir}/usr/share/konsole/EverforestDark.colorscheme"
    install -Dm644 Everforest.profile \
        "${pkgdir}/usr/share/konsole/Everforest.profile"

    # Kvantum theme
    install -Dm644 MateriaEverforestDark.kvconfig \
        "${pkgdir}/usr/share/Kvantum/MateriaEverforestDark/MateriaEverforestDark.kvconfig"
    install -Dm644 MateriaEverforestDark.svg \
        "${pkgdir}/usr/share/Kvantum/MateriaEverforestDark/MateriaEverforestDark.svg"

    # /etc/skel KDE config (applied to new users)
    install -Dm644 kdeglobals \
        "${pkgdir}/etc/skel/.config/kdeglobals"
    install -Dm644 kwinrc \
        "${pkgdir}/etc/skel/.config/kwinrc"

    # Kvantum theme selection for new users
    install -dm755 "${pkgdir}/etc/skel/.config/Kvantum"
    printf '[General]\ntheme=MateriaEverforestDark\n' \
        > "${pkgdir}/etc/skel/.config/Kvantum/kvantum.kvconfig"

    # GTK3 settings for new users
    install -Dm644 gtk-settings.ini \
        "${pkgdir}/etc/skel/.config/gtk-3.0/settings.ini"

    # Wallpapers
    install -dm755 "${pkgdir}/usr/share/backgrounds/golden-arch"
    install -Dm644 goldenarch-centered-1080p.png \
        "${pkgdir}/usr/share/backgrounds/golden-arch/goldenarch-centered-1080p.png"
    install -Dm644 goldenarch-centered-1440p.png \
        "${pkgdir}/usr/share/backgrounds/golden-arch/goldenarch-centered-1440p.png"
    install -Dm644 goldenarch-offset-1080p.png \
        "${pkgdir}/usr/share/backgrounds/golden-arch/goldenarch-offset-1080p.png"
    install -Dm644 goldenarch-offset-1440p.png \
        "${pkgdir}/usr/share/backgrounds/golden-arch/goldenarch-offset-1440p.png"

    # Hicolor app icons
    for s in 16 32 48 64 128 256 512; do
        install -Dm644 "goldenarch-${s}.png" \
            "${pkgdir}/usr/share/icons/hicolor/${s}x${s}/apps/golden-arch.png"
    done

}

post_install() {
    # Recolor Papirus folders to green
    papirus-folders -C green --theme Papirus-Dark &>/dev/null || true
    papirus-folders -C green --theme Papirus &>/dev/null || true
    papirus-folders -C green --theme Papirus-Light &>/dev/null || true
}
