# Maintainer: Golden Arch <releases@golden-arch.org>
pkgname=zen-browser-bin
pkgver=1.19.13b
pkgrel=1
pkgdesc="Firefox-based browser with a beautiful UI and strong privacy defaults"
arch=('x86_64')
url="https://zen-browser.app"
license=('MPL2')
depends=('gtk3' 'libxt' 'dbus-glib' 'alsa-lib' 'nss' 'ttf-font')
provides=('zen-browser')
conflicts=('zen-browser')
options=('!strip')
source=("zen-browser-${pkgver}.tar.xz::https://github.com/zen-browser/desktop/releases/download/${pkgver}/zen.linux-x86_64.tar.xz"
        "zen-browser.desktop")
sha256sums=('SKIP'
            'SKIP')

package() {
  install -dm755 "${pkgdir}/opt/zen-browser"
  cp -r zen/. "${pkgdir}/opt/zen-browser/"

  install -dm755 "${pkgdir}/usr/bin"
  ln -s /opt/zen-browser/zen "${pkgdir}/usr/bin/zen-browser"

  install -Dm644 zen-browser.desktop "${pkgdir}/usr/share/applications/zen-browser.desktop"

  for size in 16 32 48 64 128; do
    install -Dm644 "zen/browser/chrome/icons/default/default${size}.png" \
      "${pkgdir}/usr/share/icons/hicolor/${size}x${size}/apps/zen-browser.png" 2>/dev/null || true
  done
}
