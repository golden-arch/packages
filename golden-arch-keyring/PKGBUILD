pkgname=golden-arch-keyring
pkgver=20260510
pkgrel=1
pkgdesc="Golden Arch Linux PGP keyring"
arch=('any')
url="https://github.com/golden-arch/packages"
license=('GPL-3.0-only')
provides=('golden-arch-keyring')

package() {
    install -Dm644 golden-arch.gpg "$pkgdir/usr/share/pacman/keyrings/golden-arch.gpg"
    install -Dm644 golden-arch-trusted "$pkgdir/usr/share/pacman/keyrings/golden-arch-trusted"
}
