pkgname=golden-arch-branding
pkgver=1.0
pkgrel=1
pkgdesc="Golden Arch Linux branding — wallpapers, GRUB theme, Plymouth theme, SDDM theme"
arch=('any')
url="https://github.com/golden-arch/packages"
license=('GPL-3.0-only')
depends=(
    'grub'
    'plymouth'
    'sddm'
    'sddm-sugar-candy-git'
)
install=golden-arch-branding.install

source=(
    "forest-1.jpg"
    "forest-2.jpg"
    "forest-3.jpg"
    "forest-4.jpg"
    "forest-5.jpg"
    "forest-6.jpg"
    "forest-7.jpg"
    "forest-8.jpg"
    "mountain-1.jpg"
    "mountain-2.jpg"
    "mountain-3.jpg"
    "grub-theme.tar.gz"
    "plymouth-theme.tar.gz"
    "sddm-theme.conf"
)
sha256sums=(
    'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP'
    'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP'
)

package() {
    # Wallpapers
    local wall="${pkgdir}/usr/share/backgrounds/golden-arch"
    install -dm755 "$wall"
    for img in forest-{1..8}.jpg mountain-{1..3}.jpg; do
        install -Dm644 "$img" "$wall/$img"
    done

    # GRUB theme (tarball contains the 'golden-arch' directory)
    install -dm755 "${pkgdir}/boot/grub/themes"
    tar -xzf grub-theme.tar.gz -C "${pkgdir}/boot/grub/themes/"

    # Plymouth theme (tarball contains the 'golden-arch' directory)
    install -dm755 "${pkgdir}/usr/share/plymouth/themes"
    tar -xzf plymouth-theme.tar.gz -C "${pkgdir}/usr/share/plymouth/themes/"

    # SDDM Sugar Candy config
    install -Dm644 sddm-theme.conf \
        "${pkgdir}/usr/share/sddm/themes/sugar-candy/theme.conf"
}
