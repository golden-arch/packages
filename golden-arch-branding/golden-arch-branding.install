post_install() {
    # Apply Sugar Candy theme customisation
    local src=/usr/share/golden-arch/sddm-theme.conf
    local dst=/usr/share/sddm/themes/sugar-candy/theme.conf
    [[ -f "$src" && -d "$(dirname "$dst")" ]] && cp "$src" "$dst"

    # Set default Plymouth theme
    plymouth-set-default-theme -R golden-arch 2>/dev/null || true

    # Regenerate GRUB config to pick up new theme
    grub-mkconfig -o /boot/grub/grub.cfg 2>/dev/null || true
}

post_upgrade() {
    post_install
}
