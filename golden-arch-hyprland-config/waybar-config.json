{
    "layer": "top",
    "position": "top",
    "height": 36,
    "margin-top": 8,
    "margin-left": 12,
    "margin-right": 12,
    "spacing": 6,
    "modules-left": ["custom/launcher", "hyprland/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["pulseaudio", "backlight", "network", "custom/gpu", "cpu", "memory", "battery", "tray", "custom/power"],

    "custom/launcher": {
        "format": "◉",
        "tooltip": false,
        "on-click": "rofi -show drun"
    },

    "hyprland/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "active": "●",
            "default": "○",
            "empty": "·",
            "urgent": "▲"
        },
        "on-click": "activate",
        "sort-by-number": true
    },

    "hyprland/window": {
        "format": "{title}",
        "max-length": 50,
        "separate-outputs": true,
        "rewrite": {
            "": ""
        }
    },

    "clock": {
        "format": "{:%H:%M\n%a %d %b}",
        "format-alt": "{:%H:%M:%S\n%A %d %B %Y}",
        "tooltip-format": "<tt>{calendar}</tt>"
    },

    "cpu": {
        "format": "CPU {usage}%",
        "interval": 2,
        "tooltip": false
    },

    "memory": {
        "format": "RAM {percentage}%",
        "tooltip-format": "{used:0.1f}G / {total:0.1f}G"
    },

    "battery": {
        "states": { "warning": 30, "critical": 15 },
        "format": "BAT {capacity}%",
        "format-charging": "CHR {capacity}%",
        "format-plugged": "PLG {capacity}%",
        "format-full": "FULL",
        "format-not-charging": "BAT {capacity}%",
        "tooltip-format": "{timeTo} — {power}W"
    },

    "network": {
        "interval": 2,
        "format-wifi": "WIFI ↓{bandwidthDownBytes} ↑{bandwidthUpBytes}",
        "format-ethernet": "ETH ↓{bandwidthDownBytes} ↑{bandwidthUpBytes}",
        "format-disconnected": "OFFLINE",
        "tooltip-format": "{ifname}: {ipaddr}\n↓ {bandwidthDownBytes}/s   ↑ {bandwidthUpBytes}/s",
        "on-click": "nm-connection-editor",
        "on-click-right": "kitty -e nmtui"
    },

    "pulseaudio": {
        "format": "VOL {volume}%",
        "format-muted": "MUTED",
        "on-click": "pavucontrol",
        "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "scroll-step": 5,
        "tooltip-format": "{desc}"
    },

    "backlight": {
        "format": "BRT {percent}%",
        "format-icons": ["", "", "", "", "", "", "", "", ""],
        "on-scroll-up": "brightnessctl set 5%+",
        "on-scroll-down": "brightnessctl set 5%-",
        "tooltip": false
    },

    "tray": {
        "spacing": 8,
        "icon-size": 16
    },

    "custom/gpu": {
        "exec": "~/.config/waybar/scripts/gpu.sh",
        "format": "GPU {}%",
        "interval": 3,
        "tooltip": false
    },

    "custom/power": {
        "format": "⏻",
        "tooltip": false,
        "on-click": "hyprlock"
    }
}
