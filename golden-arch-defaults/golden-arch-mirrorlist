################################################################################
# Golden Arch Linux — default mirrorlist
# Top HTTPS mirrors sorted by reliability. Update with reflector:
#   reflector --country Germany,Netherlands,France --latest 10 \
#             --sort rate --protocol https --save /etc/pacman.d/mirrorlist
################################################################################

## Worldwide
Server = https://fastly.mirror.pkgbuild.com/$repo/os/$arch
Server = https://geo.mirror.pkgbuild.com/$repo/os/$arch

## Germany
Server = https://mirror.23media.com/archlinux/$repo/os/$arch
Server = https://de.mirrors.cicku.me/archlinux/$repo/os/$arch
Server = https://ftp.gwdg.de/pub/linux/archlinux/$repo/os/$arch

## Netherlands
Server = https://nl.mirrors.cicku.me/archlinux/$repo/os/$arch
Server = https://archlinux.mirror.pcextreme.nl/$repo/os/$arch

## France
Server = https://fr.mirrors.cicku.me/archlinux/$repo/os/$arch
Server = https://arch.repo.ouni.fr/$repo/os/$arch

## United States
Server = https://mirror.rackspace.com/archlinux/$repo/os/$arch
Server = https://mirror.arizona.edu/archlinux/$repo/os/$arch
