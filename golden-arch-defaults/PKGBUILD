pkgname=golden-arch-defaults
pkgver=1.0
pkgrel=3
pkgdesc="Golden Arch Linux system defaults — sysctl hardening, skel, mirrorlist"
arch=('any')
url="https://github.com/golden-arch/packages"
license=('GPL-3.0-only')
depends=('golden-arch-keyring')
provides=('pacman-mirrorlist')
conflicts=('pacman-mirrorlist')
replaces=('pacman-mirrorlist')
optdepends=(
    'apparmor: enforce included AppArmor profiles'
    'reflector: auto-refresh mirrorlist'
)
backup=(
    'etc/pacman.d/mirrorlist'
)
install=golden-arch-defaults.install

source=(
    "golden-arch-sysctl.conf"
    "golden-arch-pacman.conf"
    "golden-arch-mirrorlist"
    "skel-bashrc"
    "skel-zshrc"
    "skel-fishconfig"
    "motd"
    "goldenarch-motd.sh"
    "golden-arch-defaults.install"
)
sha256sums=('SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP')

package() {
    # sysctl hardening
    install -Dm644 golden-arch-sysctl.conf \
        "${pkgdir}/etc/sysctl.d/90-golden-arch.conf"

    # Mirrorlist (replaces pacman-mirrorlist)
    install -Dm644 golden-arch-mirrorlist \
        "${pkgdir}/etc/pacman.d/mirrorlist"

    # golden-arch repo snippet — included by pacman.conf via post_install
    install -Dm644 golden-arch-pacman.conf \
        "${pkgdir}/etc/pacman.d/golden-arch-repo.conf"

    # /etc/skel shell configs (zsh and fish only; .bashrc is owned by bash)
    install -Dm644 skel-zshrc   "${pkgdir}/etc/skel/.zshrc"
    install -Dm755 -d            "${pkgdir}/etc/skel/.config/fish"
    install -Dm644 skel-fishconfig \
        "${pkgdir}/etc/skel/.config/fish/config.fish"

    # Static MOTD (shown at TTY/SSH login by PAM)
    install -Dm644 motd "${pkgdir}/etc/motd"

    # Dynamic terminal greeting (runs on every interactive shell open)
    install -Dm755 goldenarch-motd.sh "${pkgdir}/etc/profile.d/goldenarch-motd.sh"
}
