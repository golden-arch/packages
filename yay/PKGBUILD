pkgname=yay
pkgver=12.4.2
pkgrel=2
pkgdesc="Yet another yogurt - An AUR Helper written in Go"
arch=('x86_64')
url="https://github.com/Jguer/yay"
license=('GPL-3.0-only')
depends=('git' 'pacman>=6.0')
makedepends=('go>=1.21')
source=("${pkgname}-${pkgver}.tar.gz::https://github.com/Jguer/yay/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
    cd "${pkgname}-${pkgver}"
    make VERSION="${pkgver}"
}

package() {
    cd "${pkgname}-${pkgver}"
    install -Dm755 yay "${pkgdir}/usr/bin/yay"
    install -Dm644 completions/bash "${pkgdir}/usr/share/bash-completion/completions/yay"
    install -Dm644 completions/zsh "${pkgdir}/usr/share/zsh/site-functions/_yay"
    install -Dm644 completions/fish "${pkgdir}/usr/share/fish/vendor_completions.d/yay.fish"
}
